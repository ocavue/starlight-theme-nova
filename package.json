{
  "name": "starlight-theme-nova-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "description": "Root package for the Starlight Nova theme monorepo",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "turbo run build",
    "preview": "pnpm run build && pnpm --filter ./website run preview",
    "lint": "pnpm run lint:eslint && pnpm run lint:prettier",
    "lint:eslint": "eslint --cache .",
    "lint:prettier": "prettier --cache --check .",
    "fix": "pnpm run fix:eslint && pnpm run fix:prettier && pnpm run build:tailwindcss",
    "fix:eslint": "eslint --cache --fix .",
    "fix:prettier": "prettier --cache --write .",
    "build:tailwindcss": "pnpm --filter ./packages/starlight-theme-nova run build",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -b",
    "test": "pnpm --filter ./website run test",
    "test:update": "pnpm --filter ./website run test:update",
    "test:install": "pnpm --filter ./website exec playwright install chromium",
    "change": "changeset",
    "ci:publish": "pnpm run build && pnpm publish --access public -r --no-git-checks --tag latest",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ocavue/eslint-config": "^4.9.1",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "pkg-pr-new": "^0.0.75",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}
